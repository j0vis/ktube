{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1080px",
      "wideSize": "1440px"
    },
    "color": {
      "background": true,
      "custom": true,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "link": true,
      "text": true
    },
    "typography": {
      "customFontSize": true,
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "lineHeight": true,
      "textAlign": true,
      "textDecoration": true,
      "textTransform": true,
      "dropCap": true,
      "fluid": true
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--ktube-color-bg)",
      "text": "var(--ktube-color-text)"
    },
    "typography": {
      "fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
      "fontSize": "var(--ktube-font-size-base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "1rem",
      "padding": {
        "top": "var(--ktube-space-md)",
        "right": "var(--ktube-space-md)",
        "bottom": "var(--ktube-space-md)",
        "left": "var(--ktube-space-md)"
      }
    },
    "elements": {
      "link": {
        "color": { "text": "var(--ktube-color-link)" }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--ktube-font-size-h1)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--ktube-font-size-h2)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--ktube-font-size-h3)",
          "fontWeight": "600",
          "lineHeight": "1.35"
        }
      }
    }
  },
  "customTemplates": [],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
